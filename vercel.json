{
  "cleanUrls": true,
  "functions": {
    "api/telegram.py": {
      "maxDuration": 30
    },
    "api/leads.py": {
      "maxDuration": 10
    },
    "api/flow.py": {
      "maxDuration": 10
    },
    "api/jb-subscribe.py": {
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "bot\\.freesignalspro\\.com" }],
      "destination": "/dashboard",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "jaybonham.com" }],
      "destination": "/jaybonham/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.jaybonham.com" }],
      "destination": "/jaybonham/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "jaybonham.com" }],
      "destination": "/jaybonham/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.jaybonham.com" }],
      "destination": "/jaybonham/:path*"
    }
  ]
}
